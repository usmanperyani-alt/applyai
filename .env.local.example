# --- AI provider (set one) ---
# Z.ai (Zhipu) — preferred. Get a key at https://z.ai or https://open.bigmodel.cn
ZAI_API_KEY=

# Anthropic Claude — fallback if ZAI_API_KEY isn't set
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: override z.ai endpoint (e.g. for the China endpoint)
# ZAI_BASE_URL=https://api.z.ai/api/paas/v4

# --- Supabase (optional — local-only mode works without these) ---
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Redis (only needed for the BullMQ background worker) ---
# REDIS_URL=redis://localhost:6379
